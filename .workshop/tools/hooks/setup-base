#!/usr/bin/env bash
set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y \
  bats \
  bind9-dnsutils \
  build-essential \
  cmake \
  curl \
  fd-find \
  file \
  gawk \
  gh \
  git \
  jq \
  kcov \
  libcap-dev \
  libgmp-dev \
  libidn2-dev \
  libmbedtls-dev \
  libreadline-dev \
  libsqlite3-dev \
  libssl-dev \
  libunistring-dev \
  libuv1-dev \
  make \
  nettle-dev \
  nodejs \
  npm \
  pre-commit \
  python3 \
  python3-pip \
  python3-venv \
  ripgrep \
  ruby \
  sed \
  shellcheck \
  snapd \
  sudo \
  tree \
  yamllint \
  wget \
  yq

ln -sf /usr/bin/fdfind /usr/local/bin/fd
if command -v node >/dev/null 2>&1 && ! command -v nodejs >/dev/null 2>&1; then
  ln -sf "$(command -v node)" /usr/local/bin/nodejs
fi

mkdir -p /etc/systemd/resolved.conf.d
cat >/etc/systemd/resolved.conf.d/snap-pi-hole-workshop.conf <<'EOF'
[Resolve]
DNS=127.0.0.1
DNSStubListener=no
EOF
systemctl restart systemd-resolved || true

systemctl enable --now snapd.socket || true
systemctl start snapd || true

for _ in $(seq 1 30); do
  if snap version >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

snap install snapcraft --channel=9.x/stable --classic
