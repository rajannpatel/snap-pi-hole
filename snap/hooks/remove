#!/bin/sh
# remove hook: restore the host's DNS configuration when the snap is removed.
#
# When Pi-hole is installed, operators must disable systemd-resolved's stub
# listener so Pi-hole can bind port 53.  If we don't clean this up on
# removal, the host is left with no local DNS resolver and no stub listener,
# which breaks name resolution for everything on the machine.
#
# This hook runs as root inside the snap's confinement. Strict confinement
# cannot manage host systemd units (snapctl only controls this snap's own
# apps), so we can't restart systemd-resolved ourselves. Instead we delete
# the drop-in we documented operators to create and print the one-line
# manual restart command for them to run.
set -eu

# Prepend snap staged paths to PATH to ensure we use our staged GNU coreutils
# rather than hitting AppArmor execution denials on the base snap's rust-coreutils.
export PATH="${SNAP}/usr/sbin:${SNAP}/usr/bin:${SNAP}/sbin:${SNAP}/bin:${PATH:-}"


RESOLVED_DROPIN="/etc/systemd/resolved.conf.d/pihole.conf"

if [ -f "$RESOLVED_DROPIN" ]; then
    rm -f "$RESOLVED_DROPIN"
    cat >&2 <<'EOF'
Pi-hole has been removed.

The systemd-resolved stub listener drop-in (/etc/systemd/resolved.conf.d/pihole.conf)
has been deleted. To restore full DNS resolution immediately, run:

    sudo systemctl restart systemd-resolved

This restores the systemd-resolved stub listener on 127.0.0.53:53 and
sets your system's /etc/resolv.conf back to the default nameservers.
EOF
fi
