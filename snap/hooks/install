#!/bin/sh
# Runs once at first install. We must explicitly create the physical 
# backing structures on the host disk so that the layout engine has 
# valid destination folders to bind-mount to.
set -eu

CONFIG_HELPER="${SNAP}/bin/config-helper.sh"

# Create the physical log path in SNAP_COMMON first to prevent daemon initialization deadlocks
mkdir -p "${SNAP_COMMON}/var/log/pihole"

# Ensure layout targets are present inside the sandbox namespace
mkdir -p "${SNAP_DATA}/etc/pihole" "${SNAP_DATA}/etc/dnsmasq.d" "${SNAP_COMMON}/var/log/pihole" "${SNAP_DATA}/run/pihole"

# Seed the static version profile template if it exists on disk
if [ -f "${SNAP:-}/opt/pihole/templates/versions" ]; then
    cp "${SNAP:-}/opt/pihole/templates/versions" "${SNAP_DATA}/etc/pihole/versions"
fi

# Attempt to migrate any existing legacy configuration into snapctl
if [ -f "$CONFIG_HELPER" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_HELPER"
    migrate_legacy_config
fi