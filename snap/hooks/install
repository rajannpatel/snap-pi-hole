#!/bin/sh
# Runs once at first install. The `layout:` block aliases /etc/pihole,
# /etc/dnsmasq.d, and /var/log/pihole to $SNAP_DATA / $SNAP_COMMON, so
# creating them here populates the right writable backing directories.
#
# /run/pihole has no layout because snapd disallows layouts that introduce
# a new top-level /run/* dir; we put the runtime state under $SNAP_DATA
# instead, which is natively writable.
set -eu

mkdir -p /etc/pihole /etc/dnsmasq.d /var/log/pihole "${SNAP_DATA}/run/pihole"
