#!/bin/sh
# Runs once at first install. We must explicitly create the physical 
# backing structures inside $SNAP_DATA and $SNAP_COMMON so that the 
# layout engine has valid destination folders to bind-mount to.
set -eu

# 1. Create the true physical backing directories on the host disk
mkdir -p "${SNAP_DATA}/etc/pihole"
mkdir -p "${SNAP_DATA}/etc/dnsmasq.d"
mkdir -p "${SNAP_DATA}/run/pihole"
mkdir -p "${SNAP_COMMON}/var/log/pihole"

# 2. Seed the static version profile template into the writable tree
if [ ! -f "${SNAP_DATA}/etc/pihole/versions" ]; then
    cp "${SNAP}/opt/pihole/templates/versions" "${SNAP_DATA}/etc/pihole/versions"
fi