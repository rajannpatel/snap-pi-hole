#!/bin/sh
# configure hook: validates and applies `snap set snap-pi-hole ftl.<key>=<value>`
# configurations by acting as a transparent proxy to pihole-FTL's configuration subsystem.

set -eu

# Prepend snap staged paths to PATH to ensure we use our staged GNU coreutils
# rather than hitting AppArmor execution denials on the base snap's rust-coreutils.
export PATH="${SNAP}/usr/sbin:${SNAP}/usr/bin:${SNAP}/sbin:${SNAP}/bin:${PATH:-}"


FTL_BIN="${SNAP}/usr/bin/pihole-FTL"
CONFIG_HELPER="${SNAP}/bin/pihole-config.sh"

if [ ! -r "$CONFIG_HELPER" ]; then
    echo "Error: missing configuration helper at $CONFIG_HELPER" >&2
    exit 1
fi

# shellcheck source=snap/local/runtime/pihole-config.sh
. "$CONFIG_HELPER"

pihole_timer_requested_schedule() {
    printf '%s\n' "$1" | jq -r '
      if type == "object" then
        (."gravity-sync".schedule // ."gravity-sync"."on-calendar" // ."gravity-sync".on_calendar // empty)
      else
        empty
      end
    ' 2>/dev/null || true
}

pihole_systemd_day() {
    case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
        sun|sunday) printf '%s\n' "Sun" ;;
        mon|monday) printf '%s\n' "Mon" ;;
        tue|tues|tuesday) printf '%s\n' "Tue" ;;
        wed|wednesday) printf '%s\n' "Wed" ;;
        thu|thur|thurs|thursday) printf '%s\n' "Thu" ;;
        fri|friday) printf '%s\n' "Fri" ;;
        sat|saturday) printf '%s\n' "Sat" ;;
        *) return 1 ;;
    esac
}

pihole_normalize_clock_time() {
    printf '%s\n' "$1" | awk -F: '
NF == 2 || NF == 3 {
    if ($1 !~ /^[0-9][0-9]?$/ || $2 !~ /^[0-9][0-9]?$/ || (NF == 3 && $3 !~ /^[0-9][0-9]?$/)) {
        exit 1;
    }
    hour = $1 + 0;
    minute = $2 + 0;
    second = (NF == 3 ? $3 + 0 : 0);
    if (hour > 23 || minute > 59 || second > 59) {
        exit 1;
    }
    printf "%02d:%02d:%02d\n", hour, minute, second;
    found = 1;
}
END {
    exit found ? 0 : 1;
}
'
}

pihole_clock_seconds() {
    printf '%s\n' "$1" | awk -F: '{ print (($1 + 0) * 3600) + (($2 + 0) * 60) + ($3 + 0) }'
}

pihole_timer_schedule_to_systemd() {
    raw_schedule="$(printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    TIMER_ON_CALENDAR=""
    TIMER_RANDOMIZED_DELAY="0"

    [ -n "$raw_schedule" ] || return 1

    case "$raw_schedule" in
        *[!\ a-zA-Z0-9:~,._/-]*)
            return 1
            ;;
        *[[:space:]]*)
            TIMER_ON_CALENDAR="$raw_schedule"
            return 0
            ;;
    esac

    old_ifs="$IFS"
    IFS=","
    # shellcheck disable=SC2086 # Intentionally split the snap timer value on commas.
    set -- $raw_schedule
    IFS="$old_ifs"

    if [ "$#" -eq 1 ]; then
        calendar_prefix="*-*-*"
        time_spec="$1"
    elif [ "$#" -eq 2 ]; then
        systemd_day="$(pihole_systemd_day "$1")" || return 1
        calendar_prefix="${systemd_day} *-*-*"
        time_spec="$2"
    else
        return 1
    fi

    start_spec="${time_spec%%~*}"
    end_spec=""
    if [ "$start_spec" != "$time_spec" ]; then
        end_spec="${time_spec#*~}"
    fi

    start_time="$(pihole_normalize_clock_time "$start_spec")" || return 1

    if [ -n "$end_spec" ]; then
        end_time="$(pihole_normalize_clock_time "$end_spec")" || return 1
        start_seconds="$(pihole_clock_seconds "$start_time")"
        end_seconds="$(pihole_clock_seconds "$end_time")"
        if [ "$end_seconds" -lt "$start_seconds" ]; then
            end_seconds=$((end_seconds + 86400))
        fi
        TIMER_RANDOMIZED_DELAY=$((end_seconds - start_seconds))
    fi

    TIMER_ON_CALENDAR="${calendar_prefix} ${start_time}"
    return 0
}

pihole_shell_quote() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

# Reject attempts to reconfigure the gravity-sync timer via `snap set`.
# Snap application timers are static: snapd has no mechanism to change them at
# runtime, and a strictly-confined hook cannot write to /etc/systemd/system.
# Point the operator at the supported host-side systemd drop-in instead with a
# copy/paste command. A non-zero exit here rolls back the whole `snap set`
# transaction, so the rejected key is never persisted into snapctl.
timer_cfg="$(snapctl get -d timer 2>/dev/null || true)"
timer_cfg_compact="$(printf '%s' "$timer_cfg" | tr -d '[:space:]')"
if [ -n "$timer_cfg_compact" ] && [ "$timer_cfg_compact" != "{}" ]; then
    snap_name="$(pihole_snap_name)"
    timer_unit="snap.${snap_name}.gravity-sync.timer"
    override_dir="/etc/systemd/system/${timer_unit}.d"
    override_file="${override_dir}/override.conf"
    requested_schedule="$(pihole_timer_requested_schedule "$timer_cfg")"
    on_calendar="Mon *-*-* 02:00:00"
    randomized_delay="0"
    translated_schedule=0

    if [ -n "$requested_schedule" ] && pihole_timer_schedule_to_systemd "$requested_schedule"; then
        on_calendar="$TIMER_ON_CALENDAR"
        randomized_delay="$TIMER_RANDOMIZED_DELAY"
        translated_schedule=1
    fi

    quoted_override_dir="$(pihole_shell_quote "$override_dir")"
    quoted_override_file="$(pihole_shell_quote "$override_file")"
    quoted_timer_unit="$(pihole_shell_quote "$timer_unit")"
    quoted_on_calendar="$(pihole_shell_quote "OnCalendar=$on_calendar")"
    quoted_randomized_delay="$(pihole_shell_quote "RandomizedDelaySec=$randomized_delay")"

    {
        cat <<EOF
Error: the gravity-sync schedule cannot be changed with 'snap set'.

Snap application timers are static, and strict confinement prevents this hook
from editing host systemd units. Use a host-side systemd drop-in instead.
EOF
        if [ -n "$requested_schedule" ]; then
            printf '\nRequested value: %s\n' "$requested_schedule"
            if [ "$translated_schedule" -eq 1 ]; then
                printf 'Equivalent systemd OnCalendar: %s\n' "$on_calendar"
                printf 'Equivalent RandomizedDelaySec: %s\n' "$randomized_delay"
            else
                printf 'Could not translate that value automatically; using an example OnCalendar below.\n'
            fi
        fi

        cat <<EOF

Copy/paste this single host command. It includes the required blank
OnCalendar= reset before the replacement value:

EOF
        printf "  sudo install -d %s && \\\\\n" "$quoted_override_dir"
        printf "    printf '%%s\\\\n' '[Timer]' 'OnCalendar=' %s %s | \\\\\n" "$quoted_on_calendar" "$quoted_randomized_delay"
        printf "    sudo tee %s >/dev/null && \\\\\n" "$quoted_override_file"
        printf "    sudo systemctl daemon-reload && \\\\\n"
        printf "    sudo systemctl restart %s\n\n" "$quoted_timer_unit"
        printf "Verify with: systemctl list-timers %s\n" "$quoted_timer_unit"
    } >&2
    exit 1
fi

# Function to parse snapctl JSON configuration tree into flat FTL key=value configuration lines.
# For array values, it formats them as TOML/JSON array strings (e.g. ["a","b"]) to satisfy FTL v6 array requirements.
get_flat_config() {
    echo "$1" | jq -r '
      paths as $p |
      select(getpath($p) | type != "object") |
      select(($p | length == 0) or (getpath($p[:-1]) | type == "object")) |
      getpath($p) as $v |
      {
        key: ($p | join(".") | sub("^ftl\\."; "")),
        value: (if ($v | type == "array") then ($v | @json) else ($v | tostring) end)
      } |
      "\(.key)=\(.value)"
    ' 2>/dev/null || echo ""
}

# Configuration key migrations. Keep this structured so key names are not
# parsed through shell word-splitting or ad hoc delimiters.
MIGRATIONS_JSON='[
  {"old": "dns.dnssec", "new": "dns.dnssec_enabled"}
]'

get_migration_target() {
    printf '%s\n' "$MIGRATIONS_JSON" | jq -r --arg key "$1" '
      first(.[] | select(.old == $key) | .new) // ""
    '
}

# Extract the config to check for migrations
ftl_json=$(snapctl get -d ftl)
flat_config=$(get_flat_config "$ftl_json")

need_reload=0
if [ -n "$flat_config" ]; then
    while IFS='=' read -r key val; do
        [ -z "$key" ] && continue
        new_key="$(get_migration_target "$key")"
        [ -n "$new_key" ] || continue

        echo "Migrating deprecated configuration parameter: ftl.${key} -> ftl.${new_key}" >&2
        snapctl set "ftl.${new_key}=${val}"
        snapctl unset "ftl.${key}"
        need_reload=1
    done <<EOF
$flat_config
EOF
fi

if [ "$need_reload" -eq 1 ]; then
    # Re-read the config after migrations
    ftl_json=$(snapctl get -d ftl)
    flat_config=$(get_flat_config "$ftl_json")
fi

TOML_FILE="$(pihole_toml_file)"

# Ensure pihole.toml is seeded first if it doesn't exist, so FTL has a valid file to read/modify.
pihole_seed_default_toml "$TOML_FILE"

# Fetch flat configuration from the existing pihole.toml file (if present)
current_toml_flat=""
if [ -f "$TOML_FILE" ]; then
    current_toml_flat=$(pihole_toml_flat "$TOML_FILE" 2>/dev/null || echo "")
fi

# Apply migrated configuration to FTL
config_changed=$(pihole_apply_flat_config "$FTL_BIN" "$flat_config" "$current_toml_flat")

# Restart the daemon if it's currently running, so changes take effect immediately
if [ "$config_changed" -eq 1 ]; then
    ftl_service="$(pihole_ftl_service_name)"
    if pihole_ftl_is_active "$ftl_service"; then
        snapctl restart "$ftl_service"
    fi
fi
