#!/bin/sh
# configure hook: validates and applies `snap set snap-pi-hole ftl.<key>=<value>`
# configurations by acting as a transparent proxy to pihole-FTL's configuration subsystem.

set -eu

FTL_BIN="${SNAP}/usr/bin/pihole-FTL"

# Extract the entire 'ftl' config namespace and pass directly to pihole-FTL
snapctl get -d ftl | python3 -c '
import sys, json, subprocess

def flatten(d, parent_key=""):
    items = []
    if not isinstance(d, dict):
        return items
    for k, v in d.items():
        new_key = f"{parent_key}.{k}" if parent_key else k
        if isinstance(v, dict):
            items.extend(flatten(v, new_key))
        else:
            items.append((new_key, v))
    return items

try:
    raw = sys.stdin.read()
    print(f"RAW STDIN: {repr(raw)}", file=sys.stderr)
    cfg = json.loads(raw)
except Exception as e:
    print(f"JSON Load Exception: {e}", file=sys.stderr)
    sys.exit(0)

if not cfg:
    sys.exit(0)

items = flatten(cfg)
for k, v in items:
    if isinstance(v, bool):
        val = "true" if v else "false"
    elif isinstance(v, list):
        # Flatten snapctl arrays to comma-separated lists for FTL
        val = ",".join(str(i) for i in v)
    else:
        val = str(v)
    
    # Let FTL validate and apply its own configuration
    import os
    res = os.system(f"\"{sys.argv[1]}\" --config {k} \"{val}\" >/dev/null 2>&1")
    if res != 0:
        print(f"Error applying ftl.{k}={val}", file=sys.stderr)
        sys.exit(1)
' "$FTL_BIN"

# Restart the daemon if it's currently running, so changes take effect immediately
if snapctl services pihole.pihole-ftl 2>/dev/null | awk 'NR>1 {print $3}' | grep -qx active; then
    snapctl restart pihole.pihole-ftl
fi
