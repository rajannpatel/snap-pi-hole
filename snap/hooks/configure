#!/bin/sh
# configure hook: validates and applies `snap set snap-pi-hole ftl.<key>=<value>`
# configurations by acting as a transparent proxy to pihole-FTL's configuration subsystem.

set -eu

# Prepend snap staged paths to PATH to ensure we use our staged GNU coreutils
# rather than hitting AppArmor execution denials on the base snap's rust-coreutils.
export PATH="${SNAP}/usr/sbin:${SNAP}/usr/bin:${SNAP}/sbin:${SNAP}/bin:${PATH:-}"


FTL_BIN="${SNAP}/usr/bin/pihole-FTL"

# Reject attempts to reconfigure the gravity-sync timer via `snap set`.
# Snap application timers are static: snapd has no mechanism to change them at
# runtime, and a strictly-confined hook cannot write to /etc/systemd/system.
# Point the operator at the supported host-side systemd drop-in instead. A
# non-zero exit here rolls back the whole `snap set` transaction, so the
# rejected key is never persisted into snapctl.
timer_cfg="$(snapctl get -d timer 2>/dev/null || true)"
timer_cfg_compact="$(printf '%s' "$timer_cfg" | tr -d '[:space:]')"
if [ -n "$timer_cfg_compact" ] && [ "$timer_cfg_compact" != "{}" ]; then
    cat >&2 <<EOF
Error: the gravity-sync schedule cannot be changed with 'snap set'.

Snap application timers are static. To customize when gravity is updated, add
a systemd drop-in override on the host (OnCalendar= must be reset first, since
systemd treats it as additive):

  sudo mkdir -p /etc/systemd/system/snap.${SNAP_NAME}.gravity-sync.timer.d
  printf '[Timer]\nOnCalendar=\nOnCalendar=Mon *-*-* 02:00:00\nRandomizedDelaySec=0\n' | \\
    sudo tee /etc/systemd/system/snap.${SNAP_NAME}.gravity-sync.timer.d/override.conf
  sudo systemctl daemon-reload
  sudo systemctl restart snap.${SNAP_NAME}.gravity-sync.timer

Verify with: systemctl list-timers 'snap.${SNAP_NAME}.gravity-sync.timer'
EOF
    exit 1
fi

# Function to parse snapctl JSON configuration tree into flat FTL key=value configuration lines.
# For array values, it formats them as TOML/JSON array strings (e.g. ["a","b"]) to satisfy FTL v6 array requirements.
get_flat_config() {
    echo "$1" | jq -r '
      paths as $p |
      select(getpath($p) | type != "object") |
      select(($p | length == 0) or (getpath($p[:-1]) | type == "object")) |
      getpath($p) as $v |
      {
        key: ($p | join(".") | sub("^ftl\\."; "")),
        value: (if ($v | type == "array") then ($v | @json) else ($v | tostring) end)
      } |
      "\(.key)=\(.value)"
    ' 2>/dev/null || echo ""
}

# Migration mapping: "old_key:new_key"
MIGRATIONS="dns.dnssec:dns.dnssec_enabled"

# Extract the config to check for migrations
ftl_json=$(snapctl get -d ftl)
flat_config=$(get_flat_config "$ftl_json")

need_reload=0
if [ -n "$flat_config" ]; then
    while IFS='=' read -r key val; do
        [ -z "$key" ] && continue
        for migration in $MIGRATIONS; do
            old_key="${migration%%:*}"
            new_key="${migration#*:}"
            if [ "$key" = "$old_key" ]; then
                echo "Migrating deprecated configuration parameter: ftl.${old_key} -> ftl.${new_key}" >&2
                snapctl set "ftl.${new_key}=${val}"
                snapctl unset "ftl.${old_key}"
                need_reload=1
            fi
        done
    done <<EOF
$flat_config
EOF
fi

if [ "$need_reload" -eq 1 ]; then
    # Re-read the config after migrations
    ftl_json=$(snapctl get -d ftl)
    flat_config=$(get_flat_config "$ftl_json")
fi

# Apply migrated configuration to FTL
if [ -n "$flat_config" ]; then
    while IFS='=' read -r key val; do
        if [ -n "$key" ]; then
            "$FTL_BIN" --config "$key" "$val" >/dev/null 2>&1 || {
                echo "Error applying ftl.$key=$val" >&2
                exit 1
            }
        fi
    done <<EOF
$flat_config
EOF
fi

# Restart the daemon if it's currently running, so changes take effect immediately
if snapctl services "${SNAP_NAME}".pihole-ftl 2>/dev/null | awk 'NR>1 {print $3}' | grep -qx active; then
    snapctl restart "${SNAP_NAME}".pihole-ftl
fi
