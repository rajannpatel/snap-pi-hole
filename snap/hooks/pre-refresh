#!/bin/sh
# pre-refresh hook: warn the operator that a snap refresh will momentarily
# hand off DNS to the new FTL revision and snapshot critical state.
#
# With `refresh-mode: endure` the old FTL process keeps serving DNS until
# the new revision's daemon is ready, so the outage window is minimal.
# This message is informational only; returning a non-zero exit code from
# a pre-refresh hook would abort the refresh entirely (not what we want).
set -eu

# Prepend snap staged paths to PATH to ensure we use our staged GNU coreutils
# rather than hitting AppArmor execution denials on the base snap's rust-coreutils.
export PATH="${SNAP}/usr/sbin:${SNAP}/usr/bin:${SNAP}/sbin:${SNAP}/bin:${PATH:-}"


# Snapshot critical state (configuration and gravity database)
# This provides a manual rollback point if the refresh severely corrupts data.
SNAPSHOT_DIR="${SNAP_COMMON}/snapshots"
mkdir -p "$SNAPSHOT_DIR"
TIMESTAMP="$(date +%Y%m%d%H%M%S)"
SNAPSHOT_FILE="${SNAPSHOT_DIR}/pihole-backup-${TIMESTAMP}.tar.gz"

if [ -d "${SNAP_DATA}/etc/pihole" ]; then
    # Create a quick snapshot of /etc/pihole in the background (avoid blocking for too long)
    # Exclude large FTL databases which are ephemeral anyway.
    tar -czf "$SNAPSHOT_FILE" --exclude='pihole-FTL.db' -C "${SNAP_DATA}/etc" pihole >/dev/null 2>&1 || true
    # Keep only the last 3 snapshots to save space
    # shellcheck disable=SC2012
    ls -1t "${SNAPSHOT_DIR}"/pihole-backup-*.tar.gz 2>/dev/null | tail -n +4 | xargs -I {} rm -f {} || true
fi

cat >&2 <<EOF
Pi-hole snap is refreshing (DNS hand-off notice):
The running Pi-hole FTL daemon will continue serving DNS for all clients
on your network while the new snap revision is prepared.

A snapshot of your configuration and Gravity database has been saved to:
${SNAP_COMMON}/snapshots/

Once the new revision is ready, snapd will start the updated FTL and
then gracefully stop the old one (refresh-mode: endure). The hand-off
window is typically under 5 seconds.

  • Existing DNS queries will complete normally.
  • New queries may briefly see SERVFAIL during the swap.
  • No manual intervention is required.

To confirm the new revision is healthy after the refresh:
  sudo snap logs ${SNAP_NAME:-pihole}.pihole-ftl | tail -20
  dig +short @127.0.0.1 example.com
EOF
