#!/bin/sh
# post-refresh hook: re-applies snapctl configuration to ensure any schema
# migrations are processed, and validates DNS resolution.
set -eu

# Prepend snap staged paths to PATH to ensure we use our staged GNU coreutils
# rather than hitting AppArmor execution denials on the base snap's rust-coreutils.
export PATH="${SNAP}/usr/sbin:${SNAP}/usr/bin:${SNAP}/sbin:${SNAP}/bin:${PATH:-}"

CONFIG_HELPER="${SNAP:-}/bin/pihole-config.sh"

if [ ! -r "$CONFIG_HELPER" ]; then
    echo "Error: missing configuration helper at $CONFIG_HELPER" >&2
    exit 1
fi

# shellcheck source=snap/local/runtime/pihole-config.sh
. "$CONFIG_HELPER"

HOOK_DIR="$(dirname "$0")"

# Update the static version profile template during upgrade/refresh
pihole_seed_versions_file

# Sync local configuration back to snapctl database to treat it as the single source of truth
if [ -x "${SNAP:-}/bin/config-sync" ]; then
    "${SNAP:-}/bin/config-sync" || echo "Warning: configuration sync failed" >&2
else
    echo "Warning: config-sync not found or not executable at ${SNAP:-}/bin/config-sync" >&2
fi

# Re-apply configuration. We can just call the configure hook logic.
if [ -x "${HOOK_DIR}/configure" ]; then
    if ! "${HOOK_DIR}/configure"; then
        echo "Error: Configuration schema migration failed! Aborting refresh." >&2
        exit 1
    fi
else
    echo "Warning: configure hook not found or not executable at ${HOOK_DIR}/configure" >&2
fi

# Run database schema migrations / gravity rebuilds. Since this requires external
# internet connectivity to download adlists, failures here are warning-only to
# prevent transient network outages from triggering false-positive rollbacks.
# Trade-off: a genuine gravity schema-migration failure is also non-fatal here;
# it is left to surface on the next gravity-sync timer or manual `pihole -g`
# rather than rolling back an otherwise-healthy refresh.
if [ -x "${SNAP:-}/bin/launcher-pihole" ]; then
    echo "Running database schema migrations..."
    if ! "${SNAP:-}/bin/launcher-pihole" -g >/dev/null 2>&1; then
        echo "Warning: Database migration/gravity update failed. This may be due to a transient network issue." >&2
    fi
else
    echo "Warning: launcher-pihole not found or not executable at ${SNAP:-}/bin/launcher-pihole" >&2
fi

# Only validate DNS resolution if the FTL service is actually running.
# We gate on the "Current" state (active), not "Startup" (enabled): a probe is
# only meaningful when FTL is up. This skips validation when FTL is not running
# for any reason  -  disabled at install (install-mode: disable), manually
# stopped by the operator, or mid-restart  -  avoiding false-positive rollbacks.
# (The configure hook reads the same column to decide whether to restart FTL.)
FTL_ACTIVE=false
if pihole_ftl_is_active; then
    FTL_ACTIVE=true
fi

if [ "$FTL_ACTIVE" = "true" ]; then
    # Give the daemon a moment to settle if it was restarted
    sleep 2

    # Validate DNS resolution
    # We use dig if available to test local resolution.
    DNS_TARGET="127.0.0.1"

    echo "Validating DNS resolution on $DNS_TARGET after refresh..."
    if command -v dig >/dev/null 2>&1; then
        # Test `pi.hole` (local) instead of github.com to avoid false-positive rollbacks
        # if the upstream internet connection is temporarily down.
        # We retry a few times to give FTL time to start up.
        healthy=0
        for _i in $(seq 1 5); do
            if dig +short +time=1 +tries=1 @${DNS_TARGET} pi.hole >/dev/null 2>&1; then
                healthy=1
                break
            fi
            sleep 1
        done

        if [ "$healthy" -eq 0 ]; then
            echo "Error: DNS validation failed after refresh! FTL is unresponsive. Aborting refresh." >&2
            exit 1
        fi
    else
        echo "Warning: 'dig' not found, skipping deep DNS validation." >&2
    fi
else
    echo "Warning: FTL service is not running. Skipping DNS validation." >&2
fi
