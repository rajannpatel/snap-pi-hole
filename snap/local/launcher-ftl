#!/bin/bash
# Daemon launcher for pihole-FTL inside the snap sandbox.
#
# Path remapping is handled by the `layout:` block in snapcraft.yaml,
# so /etc/pihole and /var/log/pihole already point at writable snap data
# dirs by the time this script runs. The PID file lives in /etc/pihole/
# (layout-mounted) so it is accessible to ALL snap apps regardless of
# the snap's published store name.
set -eu


# Detect the most common port-53 collision: systemd-resolved's stub
# listener on 127.0.0.53. Fail fast with a clear message  -  otherwise
# FTL itself would die later with a generic EADDRINUSE that's harder
# to diagnose from `snap logs`.
#
# /dev/tcp is a bash builtin and uses ordinary socket(2); the `network`
# plug is enough.
if (exec 3<>/dev/tcp/127.0.0.53/53) 2>/dev/null; then
    exec 3<&- 3>&-
    cat >&2 <<EOF
ERROR: systemd-resolved is listening on 127.0.0.53:53 and will conflict
with Pi-hole on port 53.

Disable its stub listener and try again:

    sudo mkdir -p /etc/systemd/resolved.conf.d
    printf '[Resolve]\nDNSStubListener=no\n' \
      | sudo tee /etc/systemd/resolved.conf.d/pihole.conf
    sudo systemctl restart systemd-resolved

Then: sudo snap start ${SNAP_NAME}.pihole-ftl

For a full diagnostic readout of port conflicts, run:
    sudo ${SNAP_NAME}.check-system
EOF
    exit 1
elif (exec 3<>/dev/tcp/127.0.0.1/53) 2>/dev/null || (exec 3<>/dev/tcp/0.0.0.0/53) 2>/dev/null; then
    exec 3<&- 3>&-
    cat >&2 <<EOF
ERROR: Port 53 is already in use by another service on this host.
Pi-hole requires port 53 to function.

Run 'sudo ss -tulpn | grep :53' on the host to identify the conflicting service.

For a full diagnostic readout of port conflicts, run:
    sudo ${SNAP_NAME}.check-system
EOF
    exit 1
fi

mkdir -p /etc/pihole /etc/dnsmasq.d /var/log/pihole "${SNAP_DATA}/run/pihole"

# Seed a default config on first boot. FTL requires upstream servers to be configured
# in order to resolve adlist domains during the initial background gravity sync.
if [ ! -f /etc/pihole/pihole.toml ]; then
    cat > /etc/pihole/pihole.toml <<EOF
[dns]
  upstreams = [
    "8.8.8.8",
    "8.8.4.4"
  ]
EOF
fi

# Some scripts (and a few FTL code paths) assume $HOME is writable.
export HOME="${SNAP_DATA}"

# FTL sometimes behaves better when started from a writable directory.
cd "${SNAP_DATA}/run/pihole"

# If gravity.db is missing (e.g. on first install), build it in the background.
# We sleep for 10 seconds to ensure the FTL daemon has fully initialized
# and bound to its sockets before pihole -g attempts to communicate with it.
if [ ! -s "/etc/pihole/gravity.db" ]; then
    echo "gravity.db is missing. Spawning 'pihole -g' in the background to build adlists..."
    ( 
      sleep 10
      "${SNAP}/usr/bin/pihole-FTL" sqlite3 /etc/pihole/gravity.db "INSERT OR IGNORE INTO adlist (address, enabled, comment) VALUES ('https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts', 1, 'Default Steven Black List');" || true
      "${SNAP}/opt/pihole/pihole" -g > /var/log/pihole/gravity-first-run.log 2>&1 
    ) &
fi

exec "${SNAP}/usr/bin/pihole-FTL" no-daemon