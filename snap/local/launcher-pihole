#!/bin/bash
# CLI launcher: `snap run pihole.pihole <args>` → upstream `pihole` script.
#
# The upstream script hardcodes paths like /opt/pihole, /etc/pihole, etc.
# We export the remapped paths and let the script honour them where it can;
# subcommands that still bake in absolute paths are tracked in README.md
# under "Open work".
set -eu

. "${SNAP}/etc/pihole-paths.env"

# Make the supporting scripts findable.
PATH="${PIHOLE_INSTALL_DIR}:${PIHOLE_SCRIPT_DIR}:${PATH}"
export PATH

exec "${PIHOLE_INSTALL_DIR}/pihole" "$@"
