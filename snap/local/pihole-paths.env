# Path remapping for Pi-hole inside the snap sandbox.
# Sourced by both launcher-ftl and launcher-pihole so the daemon and CLI
# agree on where state lives.
#
# Pi-hole upstream hardcodes most of these to /etc/pihole, /var/log/pihole,
# /run/pihole, etc. We remap them under $SNAP_DATA (per-revision, survives
# refresh via the standard data-copy) and $SNAP_COMMON (cross-revision, used
# for large/append-only files like the query log).

# Per-revision writable state — config, gravity DB, leases
export PIHOLE_CONFIG_DIR="${SNAP_DATA}/etc/pihole"
export PIHOLE_DNSMASQ_DIR="${SNAP_DATA}/etc/dnsmasq.d"

# Cross-revision writable state — logs, long-term query DB
export PIHOLE_LOG_DIR="${SNAP_COMMON}/var/log/pihole"
export PIHOLE_LONGTERM_DIR="${SNAP_COMMON}/var/lib/pihole"

# Runtime — pid files, sockets
export PIHOLE_RUN_DIR="${SNAP_DATA}/run/pihole"

# Read-only assets shipped in the snap
export PIHOLE_INSTALL_DIR="${SNAP}/opt/pihole"
export PIHOLE_SCRIPT_DIR="${SNAP}/opt/pihole/scripts"
export PIHOLE_TEMPLATE_DIR="${SNAP}/opt/pihole/templates"

# Tell FTL where to find its TOML config (FTL respects this env var as of v6).
export FTLCONFFILE="${PIHOLE_CONFIG_DIR}/pihole.toml"

# HOME inside the sandbox — some shell scripts assume $HOME is writable.
export HOME="${SNAP_DATA}"
