{
  "name": "snap-pi-hole-dashboard-tests",
  "private": true,
  "type": "module",
  "devDependencies": {
    "jsdom": "^25.0.0",
    "@playwright/test": "^1.52.0",
    "c8": "^10.1.0"
  },
  "scripts": {
    "test:jsdom": "node --test dashboard-logic-tests.spec.js",
    "test:playwright": "playwright test --config playwright.config.js",
    "test:playwright:snap": "PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/snap/bin/chromium playwright test --config playwright.config.js",
    "test": "npm run test:jsdom && npm run test:playwright"
  }
}
