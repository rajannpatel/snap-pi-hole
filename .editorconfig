# EditorConfig keeps editors and AI agents from rewriting files with
# different whitespace defaults. See https://editorconfig.org/.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{py,sh,bats}]
indent_size = 4

[snap/hooks/*]
indent_size = 4

[Makefile]
indent_style = tab
