#!/usr/bin/env python3
import sys
import os
import yaml

def print_usage():
    print("Usage: tools/agent-role <router|architect|implementer|reviewer>")
    sys.exit(1)

def find_model_selection():
    env_path = os.environ.get("MODEL_SELECTION_PATH")
    if env_path:
        return env_path
    
    paths = [
        ".agents/local/model-selection.yaml",
        ".agents/models/selection.local.yaml",
        ".agents/models/selection.personal.yaml"
    ]
    for p in paths:
        if os.path.exists(p):
            return p
    return None

def _print_router_fallback():
    """Print the router banner and role file for the surface-agnostic fallback paths."""
    print("=== Multi-Agent Role Verification ===")
    print("Role:             ROUTER")
    print("Assigned Model:   (surface-agnostic intake role)")
    print("Assigned Surface: (any)")
    print("\n=== Allowed Behavior ===")
    role_file = ".agents/roles/router.md"
    if os.path.exists(role_file):
        with open(role_file, "r") as rf:
            print(rf.read().strip())
    else:
        print(f"Warning: Role guideline file '{role_file}' not found.", file=sys.stderr)

def main():
    if len(sys.argv) < 2:
        print_usage()
    
    role = sys.argv[1].lower()
    if role not in ["router", "architect", "implementer", "reviewer"]:
        print(f"Error: Unknown role '{role}'. Expected: router, architect, implementer, reviewer", file=sys.stderr)
        print_usage()
        
    model_selection_path = find_model_selection()
    if not model_selection_path:
        if role == "router":
            _print_router_fallback()
            return
        print("Error: No model selection file found. Checked paths:", file=sys.stderr)
        print("  - .agents/local/model-selection.yaml", file=sys.stderr)
        print("  - .agents/models/selection.local.yaml", file=sys.stderr)
        print("  - .agents/models/selection.personal.yaml", file=sys.stderr)
        sys.exit(1)
        
    try:
        with open(model_selection_path, "r") as f:
            data = yaml.safe_load(f)
    except Exception as e:
        print(f"Error: Failed to parse YAML file '{model_selection_path}': {e}", file=sys.stderr)
        sys.exit(1)
        
    assignments = data.get("assignments", {})
    # Router is surface-agnostic; model assignment is optional
    if role == "router" and role not in assignments:
        _print_router_fallback()
        return
    if role not in assignments:
        print(f"Error: Role '{role}' not assigned in model selection at '{model_selection_path}'.", file=sys.stderr)
        sys.exit(1)
        
    assignment = assignments[role]
    surface_id = assignment.get("surface_id")
    model = assignment.get("model")
    provider_or_gateway = assignment.get("provider_or_gateway")
    
    # Find surface details
    agent_surfaces = data.get("agent_surfaces", [])
    surface = None
    for s in agent_surfaces:
        if s.get("id") == surface_id:
            surface = s
            break
            
    print("=== Multi-Agent Role Verification ===")
    print(f"Role:             {role.upper()}")
    print(f"Assigned Model:   {model}")
    print(f"Provider/Gateway: {provider_or_gateway}")
    print(f"Assigned Surface: {surface_id}")
    
    if surface:
        cmd_exec = surface.get("command_execution", {})
        print(f"Surface Type:     {surface.get('type')}")
        providers_or_gateways = surface.get("providers_or_gateways", [])
        if providers_or_gateways:
            print("Surface Providers/Gateways:")
            for provider in providers_or_gateways:
                print(f"  - {provider}")
        elif role == "implementer":
            print("Warning: Implementer surface does not list providers_or_gateways.", file=sys.stderr)
        print(f"Shell Allowed:    {cmd_exec.get('can_run_shell')}")
        print(f"Execution Mode:   {cmd_exec.get('mode')}")
        print(f"Workshop Routed:  {cmd_exec.get('workshop_routed')}")
        print("Allowed Entrypoints:")
        for ep in cmd_exec.get("allowed_entrypoints", []):
            print(f"  - {ep}")
    else:
        print(f"Warning: Surface details for '{surface_id}' not found in agent_surfaces.", file=sys.stderr)

    if role == "implementer":
        if not provider_or_gateway:
            print("Error: Implementer provider_or_gateway must be set.", file=sys.stderr)
            sys.exit(1)
        if surface and provider_or_gateway not in surface.get("providers_or_gateways", []):
            print(
                f"Error: Implementer provider_or_gateway '{provider_or_gateway}' is not listed on surface '{surface_id}'.",
                file=sys.stderr,
            )
            sys.exit(1)
    
    print("\n=== Allowed Behavior ===")
    role_file = f".agents/roles/{role}.md"
    if os.path.exists(role_file):
        with open(role_file, "r") as rf:
            print(rf.read().strip())
    else:
        print(f"Warning: Role guideline file '{role_file}' not found.", file=sys.stderr)

if __name__ == "__main__":
    main()
