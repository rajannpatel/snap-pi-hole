#!/usr/bin/env bash
set -euo pipefail

project="snap-pi-hole"

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "${repo_root}"

run_in_workshop() {
  exec workshop run "${project}" -- shell "$@"
}

run_command() {
  local command="$1"

  case "${command}" in
    workshop\ launch*|workshop\ refresh*|workshop\ run\ "${project}"\ --*)
      exec bash -lc "${command}"
      ;;
    *)
      run_in_workshop bash -lc "${command}"
      ;;
  esac
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -c)
      shift
      run_command "${1:-}"
      ;;
    -lc|-cl)
      shift
      run_command "${1:-}"
      ;;
    -i|-l|--login)
      shift
      ;;
    *)
      run_in_workshop "$@"
      ;;
  esac
done

run_in_workshop
